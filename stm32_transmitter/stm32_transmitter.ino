JoystickPayload readJoystick() {
  JoystickPayload p;

  int16_t rawX1 = analogRead(JOYR_X);
  int16_t rawY1 = analogRead(JOYR_Y);
  int16_t offsetX1 = rawX1 - centerX1;
  int16_t offsetY1 = rawY1 - centerY1;

  if (abs(offsetX1) < deadZone) offsetX1 = 0;
  if (abs(offsetY1) < deadZone) offsetY1 = 0;

  if (offsetX1 == 0) {
    p.joyRX = 0;
  } else {
    p.joyRX = map(offsetX1, minOffsetX1, maxOffsetX1, -127, 127);
  }

  if (offsetY1 == 0) {
    p.joyRY = 0;
  } else {
    p.joyRY = map(offsetY1, minOffsetY1, maxOffsetY1, -127, 127);
  }

  int16_t rawX2 = analogRead(JOYL_X);
  int16_t rawY2 = analogRead(JOYL_Y);
  int16_t offsetX2 = rawX2 - centerX2;
  int16_t offsetY2 = rawY2 - centerY2;

  if (abs(offsetX2) < deadZone) offsetX2 = 0;
  if (abs(offsetY2) < deadZone) offsetY2 = 0;

  if (offsetX2 == 0) {
    p.joyLX = 0;
  } else {
    p.joyLX = map(offsetX2, minOffsetX2, maxOffsetX2, -127, 127);
  }

  if (offsetY2 == 0) {
    p.joyLY = 0;
  } else {
    p.joyLY = map(offsetY2, minOffsetY2, maxOffsetY2, -127, 127);
  }

  return p;
}


